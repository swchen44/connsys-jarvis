{
  "description": "Framework Base Expert lifecycle hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "always",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/framework-base-expert-session-start-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "always",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/framework-base-expert-session-end-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "always",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/framework-base-expert-pre-compact-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
